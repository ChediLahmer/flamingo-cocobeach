# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flamingo_cocobeach

# JWT
JWT_SECRET=dev-secret-change-in-production

# S3 / MinIO
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=flamingo
S3_PUBLIC_URL=http://localhost:9100
S3_REGION=us-east-1

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Email (Brevo) — used for password reset & welcome emails
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@flamingo-cocobeach.com

# Public URLs used in emails (fall back to CORS_ORIGIN / localhost)
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

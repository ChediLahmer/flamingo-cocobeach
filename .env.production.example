# ----- Production env for docker-compose.prod.yml -----
# Copy to ".env" on the server (same folder as docker-compose.prod.yml).

# Your apex domain (no scheme). The site is served here; admin at /admin.
# Also create DNS records: storage.<domain> (orange/CDN) and upload.<domain>
# (grey/DNS-only) — both A records pointing at the VPS IP.
DOMAIN=flamingococobeach.com

# Email for Let's Encrypt certificate registration.
ACME_EMAIL=admin@flamingococobeach.com

# Postgres
DB_USER=flamingo
DB_PASSWORD=change-me-strong
DB_NAME=flamingo

# MinIO / S3
S3_ACCESS_KEY=change-me-access
S3_SECRET_KEY=change-me-secret
S3_BUCKET=flamingo
S3_REGION=us-east-1

# Auth
JWT_SECRET=change-me-long-random

# Initial admin login, created once by `prisma/seed.js` (see DEPLOYMENT.md).
# Use a strong password; you can change it later from the admin panel.
ADMIN_EMAIL=admin@flamingococobeach.com
ADMIN_PASSWORD=change-me-strong-admin-pass

# Email (Brevo REST API key xkeysib-..., NOT the SMTP key; verified sender)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
